rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function sortedPair(a, b) { return a < b ? a + '_' + b : b + '_' + a; }

    // Authorizes a friendship created via invite code (as opposed to the
    // request/accept path) — either a direct "friend" code owned by the
    // other party, or a "squad" code whose squad the other party is
    // already (pre-this-write) a member of. Firestore caches repeated
    // get()/exists() calls to the same path within one rule evaluation,
    // so re-referencing invPath below isn't extra read cost.
    function friendshipViaCode(uids) {
      let code = request.resource.data.viaCode;
      let otherUid = uids[0] == request.auth.uid ? uids[1] : uids[0];
      let invPath = /databases/$(database)/documents/inviteCodes/$(code);
      return code != null && exists(invPath) && (
        (get(invPath).data.type == 'friend' && get(invPath).data.ownerUid == otherUid)
        || (get(invPath).data.type == 'squad'
            && exists(/databases/$(database)/documents/squads/$(get(invPath).data.squadId))
            && otherUid in get(/databases/$(database)/documents/squads/$(get(invPath).data.squadId)).data.memberUids)
      );
    }

    // Profile directory — readable by any signed-in user (needed for
    // username search / displaying friends), writable only by its owner.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid);
    }

    // Username -> uid reverse lookup, for uniqueness + search.
    // `create` (not `update`) is the only allowed write, and only for a
    // mapping pointing at yourself — Firestore rules distinguish create
    // vs. update by whether the doc already exists, so this is what
    // actually prevents squatting on a taken name, not just the client's
    // pre-check in social-data.js.
    match /usernames/{username} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Full private app state — never readable by anyone but the owner.
    // This is the boundary that makes the sharedProgress projection matter:
    // routines and data NOT explicitly marked shared never leave this doc.
    match /userStates/{uid} {
      allow read, write: if isOwner(uid);
    }

    // The friends-facing projection (aggregate stats + explicitly-shared
    // routines only — see computeSharedProgress in social.js). Readable by
    // the owner, or by anyone with an accepted friendship with the owner.
    match /sharedProgress/{uid} {
      allow write: if isOwner(uid);
      allow read: if isOwner(uid) ||
        (signedIn() && exists(/databases/$(database)/documents/friendships/$(sortedPair(request.auth.uid, uid))));
    }

    // Deterministic ID (fromUid_toUid) so the friendships `create` rule
    // below can look up "is there an accepted request" via a known path —
    // an auto-generated ID collection can't be queried from within a rule.
    match /friendRequests/{id} {
      allow create: if signedIn() && id == request.auth.uid + '_' + request.resource.data.toUid
        && request.resource.data.fromUid == request.auth.uid && request.resource.data.status == 'pending';
      allow read: if signedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow update: if signedIn() && resource.data.toUid == request.auth.uid && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined'];
    }

    // A friendship is the read-authorization for sharedProgress, so its
    // creation is gated two ways:
    //  1. an accepted friendRequest exists between the two uids, or
    //  2. a valid invite code (friendshipViaCode above) — trust here rests
    //     on the code itself being an unguessable random string the owner
    //     chose to share, the same model as "anyone with this link." A
    //     fully server-verified "this exact code was redeemed exactly
    //     once" check would need a Cloud Function (no deploy access to
    //     one in this environment) — documented limitation, not silently
    //     assumed safe.
    match /friendships/{id} {
      allow read: if signedIn() && request.auth.uid in resource.data.uids;
      allow create: if signedIn() && request.auth.uid in request.resource.data.uids
        && id == sortedPair(request.resource.data.uids[0], request.resource.data.uids[1])
        && (
          (exists(/databases/$(database)/documents/friendRequests/$(request.resource.data.uids[0] + '_' + request.resource.data.uids[1]))
            && get(/databases/$(database)/documents/friendRequests/$(request.resource.data.uids[0] + '_' + request.resource.data.uids[1])).data.status == 'accepted')
          || (exists(/databases/$(database)/documents/friendRequests/$(request.resource.data.uids[1] + '_' + request.resource.data.uids[0]))
            && get(/databases/$(database)/documents/friendRequests/$(request.resource.data.uids[1] + '_' + request.resource.data.uids[0])).data.status == 'accepted')
          || friendshipViaCode(request.resource.data.uids)
        );
      allow update, delete: if false;
    }

    // Invite codes: anyone signed in can resolve a code (needed to redeem
    // one), but only the owner can mint one, and codes are immutable once
    // created (no editing someone else's code to redirect it).
    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Squads: members can read; creating one requires you to be its sole
    // initial member; the shared freeze pool can only move by a delta of
    // exactly 1 per write (contribute or spend), never an arbitrary jump —
    // the closest a pure-rules setup gets to transaction-safe without a
    // Cloud Function. Joining requires a valid squad invite code (same
    // unguessable-string trust model as friendshipViaCode above) — without
    // this check anyone could add themselves to any squad and reach into
    // its shared freeze pool.
    match /squads/{squadId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if signedIn() && request.resource.data.memberUids == [request.auth.uid] && request.resource.data.freezePool == 0;
      allow update: if signedIn() && (
        (request.auth.uid in resource.data.memberUids
          && request.resource.data.memberUids == resource.data.memberUids
          && (request.resource.data.freezePool == resource.data.freezePool + 1 || request.resource.data.freezePool == resource.data.freezePool - 1))
        ||
        (request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.freezePool == resource.data.freezePool
          && request.resource.data.lastJoinCode != null
          && exists(/databases/$(database)/documents/inviteCodes/$(request.resource.data.lastJoinCode))
          && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.lastJoinCode)).data.type == 'squad'
          && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.lastJoinCode)).data.squadId == squadId)
      );
      allow delete: if false;
    }
  }
}
